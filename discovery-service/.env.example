# Discovery Service Configuration

# Scan interval in hours (how often to automatically scan configured ranges)
SCAN_INTERVAL_HOURS=24

# IP ranges to scan (CIDR notation, comma-separated)
# Example: SCAN_IP_RANGES=192.168.1.0/24,10.0.0.0/16
SCAN_IP_RANGES=

# Backend URL (main application)
BACKEND_URL=http://backend-go:8000

# Backend API key or JWT token for authentication
BACKEND_API_KEY=

# Maximum concurrent scan workers
MAX_WORKERS=100

# HTTP API port for the discovery service
PORT=8001
